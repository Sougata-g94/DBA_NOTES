40. Manual Database creation steps ?

👉 1. Set the Oracle environment variabels. 

	export ORACLE_SID=ORCL
	export ORACLE_HOME=/u01/app/oracle/product/19.0.0/dbhome_1
	export PATH=$ORACLE_HOME/bin:$PATH

👉 2. Create the initialization parameter file (PFILE) -- initORCL.ora

	db_name=ORCL
	memory_target=1G
	control_files='/u01/oradata/ORCL/control01.ctl'
	compatible='19.0.0'
	undo_management=AUTO
	undo_tablespace=UNDOTBS1
	db_block_size=8192

👉 3. Create required directories

	mkdir -p /u01/oradata/ORCL
	mkdir -p /u01/fast_recovery_area
	mkdir -p /u01/admin/ORCL/adump

👉 4. Start the instance in NOMOUNT mode

	STARTUP NOMOUNT;
	SELECT status FROM v$instance;

👉 5. Execute the CREATE DATABASE statement

	CREATE DATABASE ORCL
	USER SYS IDENTIFIED BY Oracle123
	USER SYSTEM IDENTIFIED BY Oracle123
	LOGFILE
	  GROUP 1 ('/u01/oradata/ORCL/redo01.log') SIZE 100M,
	  GROUP 2 ('/u01/oradata/ORCL/redo02.log') SIZE 100M,
	  GROUP 3 ('/u01/oradata/ORCL/redo03.log') SIZE 100M
	MAXLOGFILES 16
	MAXLOGMEMBERS 3
	MAXDATAFILES 200
	CHARACTER SET AL32UTF8
	NATIONAL CHARACTER SET AL16UTF16
	EXTENT MANAGEMENT LOCAL
	DATAFILE '/u01/oradata/ORCL/system01.dbf'
	SIZE 800M REUSE
	SYSAUX DATAFILE '/u01/oradata/ORCL/sysaux01.dbf'
	SIZE 600M REUSE
	DEFAULT TABLESPACE users
	DATAFILE '/u01/oradata/ORCL/users01.dbf'
	SIZE 100M AUTOEXTEND ON
	DEFAULT TEMPORARY TABLESPACE temp
	TEMPFILE '/u01/oradata/ORCL/temp01.dbf'
	SIZE 100M
	UNDO TABLESPACE undotbs1
	DATAFILE '/u01/oradata/ORCL/undotbs01.dbf'
	SIZE 300M AUTOEXTEND ON;

👉 6. Run Oracle catalog scripts

	@?/rdbms/admin/catalog.sql
	@?/rdbms/admin/catproc.sql


👉 7. Create an SPFILE

	CREATE SPFILE FROM PFILE;


👉 8. Restart the database:

	SHUTDOWN IMMEDIATE;
	STARTUP;

👉 9. Verify the database

	SELECT name, open_mode FROM v$database;
	SELECT instance_name, status FROM v$instance;


👉 10. Configure the listener - listener.ora & tnsnames.ora

	LISTENER =
