27. CRON tab 5 start reasons ?

👉 1st Star = Minute
-- Har hour ke 0 minute par run hoga.
-- Example: 01:00, 02:00

👉 2nd Star = Hour (0 2 * * *)
-- Matlab: Roz 2:00 AM par run hoga.
 
👉 3rd Star = Day of Month (0 2 15 * *)
-- Har month ki 15th date ko 2:00 AM par run hoga.

👉 4th Star = Month (0 2 15 6 *)
-- Matlab: Har saal 15 June ko 2:00 AM par run hoga.

👉 5th Star = Day of Week (0 2 * * 0)
-- Har Sunday ko 2:00 AM par run hoga.
-- Day of week mapping:

0 = Sunday
1 = Monday
2 = Tuesday
3 = Wednesday
4 = Thursday
5 = Friday
6 = Saturday
7 = Sunday
